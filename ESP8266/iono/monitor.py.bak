
import urllib.request, json
import time
import datetime
import pickle
from utillc import *
url = "http://192.168.1.115/data_linky"
d = {}


for i in range(1000000) :
    with urllib.request.urlopen(url) as p :
        data = json.load(p)
        #print(data)
        #print(data["Iinst"])
        time.sleep(1)
        now = datetime.datetime.now()
        d[now] = (data["Iinst"], data["papp"])
    if i % 1000 == 0 :
        EKOX(now)
        with open("data.pickle", "wb") as f:
            pickle.dump(d, f)
